{
    "manifest_version": 3,
    "name": "StockPulse",
    "version" :"1.0.0",
    "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
    "description" :"tracks live Indian and US stock prices efficiently.",
    "action":{
        "default_popup":"popup.html",
        "default_icon":{
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }

    },
    "background":{
        "service_worker":"background.js"
    },
    "permissions":["storage","alarms"],
    "host_permissions":[
     "https://query1.finance.yahoo.com/*"
     ]

     

     



}